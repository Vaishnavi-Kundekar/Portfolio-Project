{
  "name": "vaishnavi-portfolio",
  "version": "1.0.0",
  "description": "Vaishnavi's Creative Portfolio - A modern, interactive portfolio website built with Node.js and MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "build": "echo 'No build step required for this project'",
    "lint": "eslint *.js",
    "format": "prettier --write *.js *.html *.css",
    "db:setup": "mysql -u root -p < query.sql",
    "db:backup": "mysqldump -u root -p portfolio_db > backup_$(date +%Y%m%d_%H%M%S).sql",
    "server:prod": "NODE_ENV=production node server.js",
    "server:dev": "NODE_ENV=development nodemon server.js --ignore '*.html' --ignore '*.css'",
    "postinstall": "echo 'Installation complete! Run npm run dev to start development server.'"
  },
  "keywords": [
    "portfolio",
    "nodejs",
    "mysql",
    "express",
    "fullstack",
    "web-development",
    "creative",
    "responsive",
    "modern"
  ],
  "author": {
    "name": "Vaishnavi",
    "email": "vaishnavikundekar3118@gmail.com",
    "url": "https://vaishnavi-portfolio.com"
  },
  "license": "MIT",
  "homepage": "https://vaishnavi-portfolio.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaishnavi/portfolio.git"
  },
  "bugs": {
    "url": "https://github.com/vaishnavi/portfolio/issues"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.2",
    "nodemailer": "^6.9.10",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.2.4",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "avoid"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "routes/",
      "config/",
      "middleware/"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "coverage/",
      "*.test.js",
      "public/"
    ],
    "env": {
      "NODE_ENV": "development"
    },
    "delay": 1000
  },
  "directories": {
    "test": "tests",
    "doc": "docs"
  },
  "files": [
    "server.js",
    "index.html",
    "style.css",
    "script.js",
    "query.sql",
    "package.json",
    "README.md"
  ],
  "config": {
    "port": 3000,
    "database": {
      "host": "localhost",
      "name": "portfolio_db"
    }
  },
  "funding": {
    "type": "individual",
    "url": "https://buymeacoffee.com/vaishnavi"
  },
  "cpu": [
    "x64",
    "arm64"
  ],
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "preferGlobal": false,
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@9.0.0"
}
